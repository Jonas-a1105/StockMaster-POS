{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StockMasterPro",
  "version": "0.1.0",
  "identifier": "com.stockmasterpro.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StockMasterPro POS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://ve.dolarapi.com http://localhost:3000 ws://localhost:5173 ws://localhost:3000; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW51c2VkX2Zvcl9kZXZlbG9wbWVudF9rZXlfcGFpcl9oZXJlCg==",
      "endpoints": [
        "https://raw.githubusercontent.com/Jonas-a1105/StockMaster-POS/main/updater.json"
      ],
      "dialog": true
    }
  }
}
