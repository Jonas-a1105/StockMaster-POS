# ─────────────────────────────────────────────────────────────────────
#  StockMasterPro — Server environment variables
#  Copia este archivo a .env y completa los valores antes de producción.
# ─────────────────────────────────────────────────────────────────────

# Entorno: 'development' | 'production' | 'test'
NODE_ENV=development

# Puerto del servidor HTTP
PORT=3000

# ── BASE DE DATOS ────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── SEGURIDAD (REQUERIDO EN PRODUCCIÓN) ───────────────────────────────
# Mínimo 32 caracteres, recomendado 64+. Generar con: openssl rand -hex 64
# Si no se define en producción, el servidor NO arrancará (fail-fast).
JWT_SECRET=

# Si está activo, fuerza redirección 301 a HTTPS
FORCE_HTTPS=false

# ── CORS ─────────────────────────────────────────────────────────────
# Orígenes separados por coma, sin espacios. Ej: http://app.local,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LICENCIAS (Ed25519) ──────────────────────────────────────────────
# Generar con: npm run license:gen
# LICENSE_PRIVATE_KEY: NUNCA commitear al repo. Guardar en vault.
LICENSE_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=

# ── SENTRY (opcional) ────────────────────────────────────────────────
# Si está vacío, Sentry se desactiva.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── OpenTelemetry (opcional) ─────────────────────────────────────────
# Si OTEL_ENABLED=true y OTEL_EXPORTER_OTLP_ENDPOINT está definido,
# el servidor exportará traces a un collector OTLP.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=stockmaster-server

# ── SMTP (opcional, para verificación de email) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="StockMasterPro <noreply@stockmaster.local>"
